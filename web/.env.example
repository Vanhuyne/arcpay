# PaymentRouter deployed on Arc Testnet (chain 5042002)
NEXT_PUBLIC_ROUTER_ADDRESS=0x8F560cA651B89FefdcC3273960f9b56BF69EdEaE

# Neon Postgres connection string
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# JWT signing key for SIWE sessions — generate with: openssl rand -base64 32
SESSION_SECRET=

# Bearer token guarding /api/cron/reconcile — generate with: openssl rand -hex 32
CRON_SECRET=

# Optional — default to Arc Testnet public RPC if unset
# NEXT_PUBLIC_ARC_RPC_HTTP=https://rpc.testnet.arc.network
# NEXT_PUBLIC_ARC_RPC_WS=wss://rpc.testnet.arc.network
